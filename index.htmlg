<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
<title>Watch & Earn</title>

<script src="https://telegram.org/js/telegram-web-app.js"></script>

<!-- ✅ ADEXIUM IN HEAD (YOUR CODE) -->
<script type="text/javascript" src="https://cdn.tgads.space/assets/js/adexium-widget.min.js"></script>
<script type="text/javascript">
document.addEventListener('DOMContentLoaded', () => {
    window.adexiumWidget = new AdexiumWidget({
        wid: '69ac8ac6-59da-4603-a9f7-1bfe1ade4399',
        adFormat: 'interstitial'
    });
    adexiumWidget.autoMode();
});
</script>

<style>
/* ✅ ALL YOUR CSS UNCHANGED */
body {
  font-family: Arial, sans-serif;
  background: linear-gradient(135deg,#0f2027,#203a43,#2c5364);
  margin: 0;
  padding: 0;
  text-align: center;
  color:#fff;
}
/* (rest unchanged) */
</style>
</head>

<body>

<!-- ✅ ALL YOUR HTML UNCHANGED -->
<div id="joinPopup">
  <div id="popupBox">
    <h2>🚫 You must join our channel to continue</h2>
    <a id="popupButton"
       href="https://t.me/earnzoners"
       target="_blank"
       onclick="joinChannelClicked()">
       👉 Join Telegram Channel
    </a>
  </div>
</div>

<div id="mainContainer">
  <h1>🎥 Watch & Earn</h1>

  <div class="stats">
    <p>💰 Balance: $<span id="balance">0.00</span></p>
  </div>

  <button class="button" id="watchBtn">🎥 Watch Videos</button>
  <button class="button" id="taskBtn">✅ Task</button>
  <button class="button" id="withdrawBtn">💵 Withdraw</button>
  <button class="button" id="referralBtn">🔗 Copy Referral Link</button>

  <div id="taskSection" style="display:none;">
    <h3>Complete Task</h3>
    <adsgram-task id="currentTask" data-block-id="task-25604"></adsgram-task>
    <div id="taskMessage">🎉 Social task completed successfully!</div>
  </div>
</div>

<script>
const tg = window.Telegram.WebApp;
tg.expand();

const balanceKey='user_balance';
const tasksKey='tasks_completed';
const ADMIN_ID=6910486529;

let balance = localStorage.getItem(balanceKey) !== null 
  ? parseFloat(localStorage.getItem(balanceKey)) 
  : 0;

let tasksCompleted=JSON.parse(localStorage.getItem(tasksKey))||{};

const taskQueue=["task-26537","task-26541","task-26539","task-26540"];
let taskIndex=0;

function updateUI(){
  document.getElementById("balance").textContent=balance.toFixed(2);
}
updateUI();

document.getElementById("referralBtn").addEventListener("click",()=>{
  const link=`https://t.me/Postnewanbot?start=${tg.initDataUnsafe.user.id}`;
  navigator.clipboard.writeText(link);
  alert("Referral link copied!");
});

/* ✅ REWARD FUNCTION */
function addReward(amount){
  balance += amount;
  localStorage.setItem(balanceKey, balance);
  updateUI();
}

/* ✅ SIMPLE ADEXIUM TRIGGER (USED EVERYWHERE ADSGRAM WAS USED) */
function showAd(){
  if(window.adexiumWidget){
    adexiumWidget.autoMode();
  }
}

/* ✅ FIRST LOAD (REPLACED RewardAd.show) */
setTimeout(()=>{
  showAd();

  document.getElementById("joinPopup").style.display="flex";
  document.getElementById("mainContainer").style.display="none";
},3000);

function joinChannelClicked(){
  window.open("https://t.me/earnzoners","_blank");

  if(!localStorage.getItem('joined_channel')){
    addReward(0.001);
    localStorage.setItem('joined_channel',"yes");
    alert("🎉 +$0.001 rewarded!");
  }

  document.getElementById("joinPopup").style.display="none";
  document.getElementById("mainContainer").style.display="block";
}

/* COMMENT BUTTON */
const commentBtn = document.createElement("button");
commentBtn.className = "button";
commentBtn.id = "commentMenuBtn";
commentBtn.textContent = "💬 Comment";
commentBtn.style.display = "none";
document.getElementById("mainContainer").appendChild(commentBtn);

/* ✅ WATCH BUTTON (REPLACED ADSGRAM) */
document.getElementById("watchBtn").addEventListener("click", () => {
  showAd();

  setTimeout(()=>{
    commentBtn.style.display = "block";
  },3000);
});

/* ✅ EVERYTHING BELOW UNCHANGED */

/* COMMENT FLOW */
commentBtn.addEventListener("click", () => {
  commentBtn.style.display = "none";

  const taskSection = document.getElementById("taskSection");
  taskSection.style.display = "block";

  const taskMessage = document.getElementById("taskMessage");
  taskMessage.style.display = "none";

  let step = 1;

  function loadCommentTask(taskId){
    const newTask = document.createElement("adsgram-task");
    newTask.setAttribute("data-block-id", taskId);
    newTask.id = "commentTask";

    const oldTask = document.getElementById("commentTask") || document.getElementById("currentTask");
    if (oldTask) oldTask.replaceWith(newTask);

    newTask.addEventListener("reward", () => {
      if(step === 1){
        step = 2;
        loadCommentTask("task-26537");
      } else if(step === 2){
        step = 3;
        loadCommentTask("task-26538");
      } else if(step === 3){
        addReward(0.05);
        taskMessage.textContent = "🎉 You're successful comment with us, thank you for your feedback and also received $0.05 for watching videos";
        taskMessage.style.display = "block";
        setTimeout(() => { taskMessage.style.display = "none"; }, 5000);
        taskSection.style.display = "none";
      }
    });
  }

  loadCommentTask("task-26538");
});

/* TASK SYSTEM */
document.getElementById("taskBtn").addEventListener("click",()=>{
  document.getElementById("taskSection").style.display="block";
  loadTask(taskQueue[taskIndex]);
});

function loadTask(id){
  const newTask=document.createElement("adsgram-task");
  newTask.setAttribute("data-block-id",id);
  newTask.id="currentTask";
  document.getElementById("currentTask").replaceWith(newTask);

  newTask.addEventListener("reward",()=>{
    addReward(0.02);
    tasksCompleted[id]=true;
    localStorage.setItem(tasksKey,JSON.stringify(tasksCompleted));

    if(taskIndex<taskQueue.length-1){
      taskIndex++;
    }else{
      taskIndex=0;
      const msg=document.getElementById("taskMessage");
      msg.style.display="block";
      setTimeout(()=>{msg.style.display="none";},30000);
    }

    loadTask(taskQueue[taskIndex]);
  });
}

/* WITHDRAW */
document.getElementById("withdrawBtn").addEventListener("click",()=>{
  if(balance < 6) return alert("❌ Minimum withdraw is $6");

  tg.sendData(JSON.stringify({
    action:"forward_to_admin",
    admin_id:ADMIN_ID,
    user_id:tg.initDataUnsafe.user.id,
    amount:balance
  }));

  alert("✅ Withdrawal sent");
  balance=0;
  localStorage.setItem(balanceKey, balance);
  updateUI();
});
</script>

</body>
</html>
